POSTGRES_DB=denarly_db
POSTGRES_USER=denarly_user
POSTGRES_PASSWORD=denarly_pass
POSTGRES_HOST=denarly_db
POSTGRES_PORT=5432
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_SECRET_KEY=change-me-to-a-different-random-64-char-string
DEBUG=false
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Baked into the frontend bundle at build time. Set to the URL your users will hit.
VITE_API_URL=http://localhost:8000/api
# Enable demo mode in the frontend (baked into the JS bundle at Docker build time)
VITE_DEMO_MODE=false
USE_S3_STORAGE=false
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_STATIC=denarly-static
S3_BUCKET_MEDIA=denarly-media
S3_BUCKET_LOGS=denarly-logs
# Celery broker and result backend (Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Run tasks synchronously for local debugging (no worker needed)
CELERY_TASK_ALWAYS_EAGER=false
